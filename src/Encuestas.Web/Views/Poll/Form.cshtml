@model PollFormViewModel
<div class="row justify-content-center mt-3">
    <div class="col-md-8 col-lg-6">
        <partial name="_Message" />
        <h4 class="text-center mb-3">@ViewData["Title"]</h4>
        <div class="card">
            <div class="card-body">
                <form asp-controller="Poll" asp-action="@(Model.Id == 0 ? "Add" : "Update")" method="post">
                    <input type="hidden" asp-for="Id">
                    <div class="mb-3">
                        <label class="form-label" asp-for="Title">Título</label>
                        <input class="form-control" asp-for="Title">
                        <span class="text-danger small" asp-validation-for="Title"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Description">Descripción</label>
                        <textarea class="form-control" rows="3" asp-for="Description"></textarea>
                        <span class="text-danger small" asp-validation-for="Description"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Position">Posición</label>
                        <input class="form-control" type="number" min="1" asp-for="Position">
                        <span class="text-danger small" asp-validation-for="Position"></span>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Guardar</button>
                </form>
            </div>
        </div>
    </div>
</div>
