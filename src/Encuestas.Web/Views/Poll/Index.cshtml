@model List<Poll>
<div class="mt-3">
    <partial name="_Message" />
    <h4 class="text-center mb-3">@ViewData["Title"]</h4>
    @if (Model.Count == 0)
    {
        <p class="text-center text-secondary">Aún no tienes encuestas. Usa «Agregar encuesta» para crear la primera.</p>
    }
    @foreach (var item in Model)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@item.Title</h5>
                <p class="card-text">@item.Description</p>
            </div>
            <div class="card-footer d-flex flex-wrap gap-2">
                <a class="btn btn-sm btn-outline-primary" asp-controller="Poll" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                <a class="btn btn-sm btn-outline-secondary" asp-controller="Answer" asp-action="Answers" asp-route-id="@item.Id">Ver respuestas</a>
                <a class="btn btn-sm btn-outline-secondary" asp-controller="Answer" asp-action="Add" asp-route-id="@item.Id">Responder</a>
                <form asp-controller="Poll" asp-action="Delete" asp-route-id="@item.Id" method="post" class="ms-auto"
                      data-confirm="¿Estás seguro de borrar este registro?">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Borrar</button>
                </form>
            </div>
        </div>
    }
</div>
