@model ChangeEmailViewModel
<div class="row justify-content-center mt-3">
    <div class="col-md-8 col-lg-6">
        <partial name="_Message" />
        <h4 class="text-center mb-3">@ViewData["Title"]</h4>
        <div class="card">
            <div class="card-body">
                <form asp-action="ChangeEmail" method="post">
                    <div class="mb-3">
                        <label class="form-label" asp-for="Email">Correo electrónico</label>
                        <input class="form-control" type="email" asp-for="Email" autocomplete="email">
                        <span class="text-danger small" asp-validation-for="Email"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Password">Contraseña</label>
                        <input class="form-control" type="password" asp-for="Password" autocomplete="current-password">
                        <span class="text-danger small" asp-validation-for="Password"></span>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Guardar</button>
                </form>
            </div>
        </div>
    </div>
</div>
