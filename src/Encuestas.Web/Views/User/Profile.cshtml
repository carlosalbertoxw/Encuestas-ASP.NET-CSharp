@model List<Poll>
<div class="mt-3">
    <partial name="_Message" />
    <h4 class="text-center mb-3">@ViewData["Title"]</h4>
    @if (Model.Count == 0)
    {
        <p class="text-center text-secondary">Este usuario aún no tiene encuestas.</p>
    }
    @foreach (var item in Model)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@item.Title</h5>
                <p class="card-text">@item.Description</p>
            </div>
            <div class="card-footer">
                <a class="btn btn-sm btn-outline-primary" asp-controller="Answer" asp-action="Add" asp-route-id="@item.Id">Responder</a>
            </div>
        </div>
    }
</div>
