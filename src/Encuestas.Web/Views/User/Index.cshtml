@model HomeViewModel
<div class="row mt-3 g-4">
    <div class="col-12">
        <partial name="_Message" />
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title text-center mb-3">Acceso</h4>
                <form asp-controller="User" asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label" asp-for="Login.Email">Correo electrónico</label>
                        <input class="form-control" type="email" asp-for="Login.Email" autocomplete="username">
                        <span class="text-danger small" asp-validation-for="Login.Email"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Login.Password">Contraseña</label>
                        <input class="form-control" type="password" asp-for="Login.Password" autocomplete="current-password">
                        <span class="text-danger small" asp-validation-for="Login.Password"></span>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Entrar</button>
                    <div class="text-center mt-2">
                        <a asp-controller="User" asp-action="ForgotPassword">¿Olvidaste tu contraseña?</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title text-center mb-3">Registro</h4>
                <form asp-controller="User" asp-action="Register" method="post">
                    <div class="mb-3">
                        <label class="form-label" asp-for="Register.Email">Correo electrónico</label>
                        <input class="form-control" type="email" asp-for="Register.Email" autocomplete="email">
                        <span class="text-danger small" asp-validation-for="Register.Email"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Register.Password">Contraseña</label>
                        <input class="form-control" type="password" asp-for="Register.Password" autocomplete="new-password">
                        <span class="text-danger small" asp-validation-for="Register.Password"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Register.RePassword">Repita contraseña</label>
                        <input class="form-control" type="password" asp-for="Register.RePassword" autocomplete="new-password">
                        <span class="text-danger small" asp-validation-for="Register.RePassword"></span>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Registrarse</button>
                </form>
            </div>
        </div>
    </div>
</div>
