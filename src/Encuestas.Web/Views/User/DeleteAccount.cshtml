@model DeleteAccountViewModel
<div class="row justify-content-center mt-3">
    <div class="col-md-8 col-lg-6">
        <partial name="_Message" />
        <h4 class="text-center mb-3">@ViewData["Title"]</h4>
        <div class="card border-danger">
            <div class="card-body">
                <p class="text-danger">Esta acción elimina tu cuenta y todos tus datos de forma permanente.</p>
                <form asp-action="DeleteAccount" method="post" data-confirm="¿Seguro que quieres borrar tu cuenta? Esta acción no se puede deshacer.">
                    <div class="mb-3">
                        <label class="form-label" asp-for="Password">Contraseña</label>
                        <input class="form-control" type="password" asp-for="Password" autocomplete="current-password">
                        <span class="text-danger small" asp-validation-for="Password"></span>
                    </div>
                    <button class="btn btn-danger w-100" type="submit">Borrar mi cuenta</button>
                </form>
            </div>
        </div>
    </div>
</div>
