@using Encuestas.Data
@model PagedResult<Answer>
<div class="mt-3">
    <partial name="_Message" />
    <h4 class="text-center mb-1">@ViewData["Title"]</h4>
    <p class="text-center text-secondary">@Model.TotalCount respuesta(s)</p>

    @if (Model.TotalCount == 0)
    {
        <p class="text-center text-secondary">Esta encuesta aún no tiene respuestas.</p>
    }
    @foreach (var item in Model.Items)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <strong>@item.UserName</strong>
                    <span class="stars" title="@item.Stars de 5 estrellas">
                        @for (var i = 1; i <= 5; i++)
                        {
                            @(i <= item.Stars ? "★" : "☆")
                        }
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(item.Comment))
                {
                    <p class="card-text mt-2 mb-0">@item.Comment</p>
                }
            </div>
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Paginación de respuestas">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link" asp-action="Answers" asp-route-id="@ViewBag.PollId" asp-route-page="@(Model.Page - 1)">Anterior</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">@Model.Page / @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link" asp-action="Answers" asp-route-id="@ViewBag.PollId" asp-route-page="@(Model.Page + 1)">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
</div>
