@model Poll
<div class="container">
    <div class="row">
        <div class="text-center" style="margin-bottom:10px;margin-top:10px">
            @ViewBag.Message
        </div>
        <div class="row">
            <div class="col-md-offset-3 col-md-6 col-sm-12">
                <h4 class="text-center">@ViewData["Title"]</h4>
                <div class="panel panel-default">
                    <div class="panel-body">
                        @Model.Title
                        <br>
                        @Model.Description
                    </div>
                </div>
                <form class="form-horizontal" asp-controller="Answer" asp-action="Add" asp-route-id="@Model.Id" method="post" onsubmit="return add_poll_answer()">
                    <div class="form-group">
                        <label class="col-sm-4 control-label">Estrellas</label>
                        <div class="col-sm-8">
                            @for (var i = 1; i <= 5; i++)
                            {
                                <label class="radio-inline">
                                    <input type="radio" name="stars" value="@i"> @i
                                </label>
                            }
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-sm-4 control-label" for="comment">Comentario</label>
                        <div class="col-sm-8"><textarea rows="3" class="form-control" name="comment" id="comment" maxlength="1000"></textarea></div>
                    </div>
                    <div class="form-group">
                        <div class="col-sm-offset-4 col-sm-8">
                            <button class="btn btn-primary" type="submit">Enviar</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section scripts {
    <script src="~/js/public-validations.js"></script>
}
